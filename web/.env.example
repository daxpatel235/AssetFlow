# --- Database: LOCAL PostgreSQL (no cloud, runs offline) ---
# Tuning tip: append &connection_limit=10&pool_timeout=15 for a small pool that
# fails fast instead of hanging when Postgres is under load.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/odoo_web?schema=public"

# --- Auth ---
# Long random string. Generate: openssl rand -base64 48
JWT_SECRET="change_me_to_a_long_random_secret"

# Public base URL used to build password-reset links. Optional: falls back to the
# request's own origin when unset (works on any host/port in dev).
APP_URL=""

# --- Email (OPTIONAL). Unset = reset links are printed to the server console. ---
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Odoo Starter <no-reply@example.com>"

# --- Sentry (OPTIONAL error monitoring). Leave blank = fully offline, no cloud. ---
NEXT_PUBLIC_SENTRY_DSN=""
